{
	"name": "your-package-name-here",
	"version": "0.0.0",
	"type": "module",
	"repository": "github:HarperFast/create-harper",
	"scripts": {
		"agent:run": "npx -y @harperfast/agent@latest",
		"agent:skills:update": "npx -y skills@latest add harperfast/skills --all --yes",
		"start": "harper run .",
		"dev": "harper dev .",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "node --test test/*.test.js",
		"test:watch": "node --watch --test test/*.test.js",
		"build": "vite build",
		"deploy": "rm -Rf deploy && npm run build && mkdir deploy && mv web deploy/ && cp -R deploy-template/* deploy/ && cp -R schemas resources deploy/ && (cd deploy && harper deploy_component . project=web restart=true replicated=true) && rm -Rf deploy"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@harperfast/schema-codegen": "^1.0.10",
		"@harperfast/vite-plugin": "^0.2.1",
		"@vitejs/plugin-vue": "^6.0.5",
		"eslint": "^10.0.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"vite": "^8.0.0",
		"vue": "^3.5.29"
	}
}
